# Backend environment example — copy to backend/.env and fill in.

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=credsure

# ── LLM API keys (AI blog generation, topic recommendations, translation, images) ──
# Preferred: configure these in the blog admin (Settings → AI / API Keys), which
# stores them in MongoDB. These env vars are the fallback when no admin key is set.
#   - Anthropic powers blog generation / recommendations / translation
#   - OpenAI powers featured-image generation
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Google OAuth (admin sign-in — replaces Emergent-managed auth) ──
# Create an OAuth 2.0 Client (Web application) in Google Cloud → APIs & Services
# → Credentials. Add the callback below as an Authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI on the OAuth client. If unset,
# derived from BACKEND_PUBLIC_URL + /api/auth/google/callback, else the request.
OAUTH_CALLBACK_URL=https://api.credsure.io/api/auth/google/callback
# Backend public origin (used to build the callback URL when OAUTH_CALLBACK_URL is unset)
BACKEND_PUBLIC_URL=https://api.credsure.io
# First-admin / access-recovery: comma-separated emails force-activated as admin
# on Google sign-in. Clear once real admins are active. e.g. you@certif-id.com
BOOTSTRAP_ADMIN_EMAILS=
# Optional: Slack webhook for "new admin pending approval" pings
# SLACK_WEBHOOK_URL=

# Deprecated — the old Emergent universal key. No longer used; kept only as a
# last-resort fallback so legacy deployments don't hard-break. Leave empty.
# EMERGENT_LLM_KEY=
